# Copy to .env (or create .env.local for local overrides)
NODE_ENV=development
PORT=3000

# App profile: production | simulation (simulation enables Plaid/Stripe sim routes)
APP_PROFILE=simulation

# Simulation
SIMULATION_ENABLED=false
SIMULATION_ITEM_ID=
SIMULATION_INSTITUTION_ID=ins_109508
SIMULATION_INSTITUTION_NAME=
SIMULATION_INTERNAL_TOKEN=token1

# Integrations
SLACK_WEBHOOK_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_EXTERNAL_REF_ID=
STRIPE_HTTP_TIMEOUT_MS=30000

# Infrastructure
# Use REDIS_HOST=redis when the app runs inside Docker Compose
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
ERROR_DEDUP_WINDOW_SECONDS=300
# Optional error incident severity thresholds (defaults: 10 / 50 / 100)
# ERROR_SEVERITY_COUNT_HIGH=10
# ERROR_SEVERITY_COUNT_ELEVATED=50
# ERROR_SEVERITY_COUNT_CRITICAL=100
# ERROR_SEVERITY_FREQUENCY_HIGH_PER_SEC=1
# ERROR_SEVERITY_RECURRENCE_MIN_PRIOR_INCIDENTS=2
PLAID_LATENCY_THRESHOLD_MS=2000
PLAID_SIMULATION_SLOW_MS=2500
LATENCY_INCIDENT_WINDOW_SECONDS=300
# docker-compose.yml defaults:
# - user: postgres
# - password: mysecretpassword
# - db: nest_db
DATABASE_URL="postgresql://postgres:mysecretpassword@localhost:5432/nest_db?schema=public"
