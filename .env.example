# Copy to .env (or create .env.local for local overrides)
NODE_ENV=development
PORT=3000

# App profile: production | simulation (simulation enables Plaid/Stripe sim routes)
APP_PROFILE=simulation

# Simulation
SIMULATION_ENABLED=false
SIMULATION_ITEM_ID=
SIMULATION_INSTITUTION_ID=ins_109508
SIMULATION_INSTITUTION_NAME=
SIMULATION_INTERNAL_TOKEN=token1

# Integrations
SLACK_WEBHOOK_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_EXTERNAL_REF_ID=

# Infrastructure
# Use REDIS_HOST=redis when the app runs inside Docker Compose
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
ERROR_DEDUP_WINDOW_SECONDS=300
# docker-compose.yml defaults:
# - user: postgres
# - password: mysecretpassword
# - db: nest_db
DATABASE_URL="postgresql://postgres:mysecretpassword@localhost:5432/nest_db?schema=public"
