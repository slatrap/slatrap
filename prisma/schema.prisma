// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

model Item {
  id              Int     @id @default(autoincrement())
  itemId          String  @unique @map("item_id")
  institutionId   String  @map("institution_id")
  institutionName String? @map("institution_name")

  @@map("institution_items")
}

model ExternalError {
  id                 Int      @id @default(autoincrement())
  provider           String
  errorCode          String?
  errorType          String?
  errorMessage       String?
  requestId          String?
  timestamp          DateTime @default(now())
  lastSeenAt         DateTime @default(now()) @map("last_seen_at")
  latency            Int
  severity           String   @default("medium")
  metadata           Json?    @default("{}")
  count              Int      @default(1)
  endpoint           String?
  statusCode         Int?
  fingerprint        String?
  fingerprintVersion Int      @default(1) @map("fingerprint_version")
  environment        String?

  @@index([fingerprint, lastSeenAt(sort: Desc)])
  @@index([provider, errorCode, errorType, endpoint, statusCode, timestamp(sort: Desc)])
  @@index([provider, severity, lastSeenAt(sort: Desc)])
  @@map("external_errors")
}

model LatencyObservation {
  id         Int      @id @default(autoincrement())
  provider   String
  endpoint   String?
  latencyMs  Int      @map("latency_ms")
  success    Boolean  @default(true)
  statusCode Int?     @map("status_code")
  timestamp  DateTime @default(now())
  metadata   Json?    @default("{}")

  @@index([provider, endpoint, timestamp(sort: Desc)])
  @@map("latency_observations")
}

model LatencyIncident {
  id           Int      @id @default(autoincrement())
  provider     String
  endpoint     String?
  thresholdMs  Int      @map("threshold_ms")
  observedMs   Int      @map("observed_ms")
  maxLatencyMs Int      @map("max_latency_ms")
  count        Int      @default(1)
  timestamp    DateTime @default(now())
  metadata     Json?    @default("{}")

  @@index([provider, endpoint, thresholdMs, timestamp(sort: Desc)])
  @@map("latency_incidents")
}